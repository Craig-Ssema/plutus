# Plutus Environment Variables
# Add your API keys here instead of hardcoding them in the source files

# CoinGecko - No API key needed for basic use
# Get your free key for higher limits: https://www.coingecko.com/en/api

# Alpha Vantage - Free tier: 5 API calls/minute, 500/day
# Get your free API key: https://www.alphavantage.co/support/#api-key
VITE_ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY

# Twelve Data - Free tier: 800 API calls/day
# Get your free API key: https://twelvedata.com/account/api-keys
VITE_TWELVE_DATA_API_KEY=YOUR_TWELVE_DATA_API_KEY

# Finnhub - Free tier: 60 API calls/minute
# Get your free API key: https://finnhub.io/register
VITE_FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY

# Supabase (Optional - if you want to re-enable database features)
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
