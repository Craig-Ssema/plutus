import React, { useState, useEffect } from 'react';
import { AreaChart, Area, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from 'recharts';
import { TrendingUp, TrendingDown, RefreshCw } from 'lucide-react';
import { useTheme } from '@/contexts/ThemeContext';
import { cn } from '@/lib/utils';
import { fetchChartData } from '@/services/chartDataService';

const TradingChart = ({ asset }) => {
  const { theme } = useTheme();
  const [timeframe, setTimeframe] = useState('1D');
  const [chartData, setChartData] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  
  // Use ref to track ongoing requests and prevent duplicates
  const pendingRequests = React.useRef(new Set());
  const chartCache = React.useRef({});

  // Fetch real chart data when asset or timeframe changes
  useEffect(() => {
    const loadChartData = async () => {
      if (!asset || !asset.symbol) return;
      
      const cacheKey = `${asset.symbol}-${timeframe}`;
      
      // Check cache first (5 minute TTL)
      const cached = chartCache.current[cacheKey];
      if (cached && (Date.now() - cached.timestamp) < 300000) {
        console.log(`Using cached chart for ${cacheKey}`);
        setChartData(cached.data);
        setError(null);
        return;
      }
      
      // Prevent duplicate requests
      if (pendingRequests.current.has(cacheKey)) {
        console.log(`Request already pending for ${cacheKey}`);
        return;
      }
      
      pendingRequests.current.add(cacheKey);
      setLoading(true);
      setError(null);
      
      try {
        const assetType = asset.type || 'crypto';
        const response = await fetchChartData(asset.symbol, timeframe, assetType);
        
        if (response && response.ohlcv && response.ohlcv.length > 0) {
          const priceData = response.ohlcv.map(candle => ({
            time: candle.time,
            price: candle.close
          }));
          setChartData(priceData);
          
          // Cache the data
          chartCache.current[cacheKey] = {
            data: priceData,
            timestamp: Date.now()
          };
        } else {
          throw new Error('No data available');
        }
      } catch (err) {
        console.error(`Chart error for ${cacheKey}:`, err.message);
        
        // Use fallback mock data
        const basePrice = Number(asset.price) || 0;
        const mockData = Array.from({ length: 50 }, (_, i) => ({
          time: `${i}m`,
          price: basePrice + (Math.random() - 0.5) * (basePrice * 0.02),
        }));
        setChartData(mockData);
        setError('Chart unavailable');
      } finally {
        pendingRequests.current.delete(cacheKey);
        setLoading(false);
      }
    };
    
    loadChartData();
  }, [asset?.symbol, timeframe]);
  // Handle null or undefined asset
  if (!asset || !asset.price) {
    return (
      <div className={cn(
        "w-full h-full flex items-center justify-center",
        theme === 'gradient' && 'bg-white/5 rounded-lg'
      )}>
        <p className={cn(
          theme === 'dark' ? 'text-gray-400' : theme === 'gradient' ? 'text-white/70' : 'text-gray-500'
        )}>No chart data available</p>
      </div>
    );
  }

  const timeframes = ['1D', '5D', '1M', '3M', '1Y', '5Y'];

  // Use the new data structure
  const isPositive = (asset.change_24h_percent || 0) >= 0;
  const gradientColor = isPositive ? 'url(#positiveGradient)' : 'url(#negativeGradient)';
  const strokeColor = isPositive ? '#16a34a' : '#dc2626';

  // Format price based on value
  const formatPrice = (price) => {
    const num = Number(price) || 0;
    if (num >= 1000) {
      return `$${num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    } else if (num >= 1) {
      return `$${num.toFixed(2)}`;
    } else {
      return `$${num.toFixed(6)}`;
    }
  };

  return (
    <div className="w-full h-full flex flex-col p-4">
      {/* Time period selector */}
      <div className="flex gap-2 mb-4 items-center">
        {timeframes.map((tf) => (
          <button
            key={tf}
            onClick={() => setTimeframe(tf)}
            className={cn(
              "px-3 py-1 text-sm font-medium rounded-lg transition-all",
              timeframe === tf
                ? theme === 'dark'
                  ? 'bg-gradient-to-r from-red-600 to-orange-500 text-white'
                  : theme === 'gradient'
                  ? 'bg-white/20 text-white backdrop-blur-md border border-white/30'
                  : 'bg-blue-100 text-blue-600'
                : theme === 'dark'
                ? 'text-gray-400 hover:bg-zinc-800'
                : theme === 'gradient'
                ? 'text-white/70 hover:bg-white/10'
                : 'text-gray-600 hover:bg-gray-100'
            )}
          >
            {tf}
          </button>
        ))}
        {loading && (
          <RefreshCw className={cn(
            "w-4 h-4 animate-spin ml-2",
            theme === 'dark' ? 'text-gray-400' : theme === 'gradient' ? 'text-white/70' : 'text-gray-600'
          )} />
        )}
      </div>
      
      {/* Error/Info message */}
      {error && (
        <div className={cn(
          "text-xs mb-2 px-2 py-1 rounded",
          theme === 'dark' ? 'bg-yellow-900/20 text-yellow-400' : theme === 'gradient' ? 'bg-white/10 text-white/70' : 'bg-yellow-50 text-yellow-700'
        )}>
          ℹ️ {error}
        </div>
      )}

      <div className="w-full h-[400px]">
        <ResponsiveContainer width="100%" height="100%">
          <AreaChart data={chartData} margin={{ top: 5, right: 5, left: -25, bottom: 5 }}>
             <defs>
                <linearGradient id="positiveGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor={strokeColor} stopOpacity={0.8}/>
                    <stop offset="95%" stopColor={strokeColor} stopOpacity={0}/>
                </linearGradient>
                <linearGradient id="negativeGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor={strokeColor} stopOpacity={0.8}/>
                    <stop offset="95%" stopColor={strokeColor} stopOpacity={0}/>
                </linearGradient>
             </defs>
            <CartesianGrid strokeDasharray="3 3" stroke={theme === 'dark' ? '#27272a' : theme === 'gradient' ? 'rgba(255,255,255,0.1)' : '#e5e7eb'} vertical={false} />
            <XAxis dataKey="time" stroke={theme === 'dark' ? '#52525b' : theme === 'gradient' ? 'rgba(255,255,255,0.5)' : '#9ca3af'} tick={{fontSize: 12}} tickLine={false} axisLine={false} />
            <YAxis stroke={theme === 'dark' ? '#52525b' : theme === 'gradient' ? 'rgba(255,255,255,0.5)' : '#9ca3af'} tick={{fontSize: 12}} orientation="right" tickLine={false} axisLine={false} domain={['dataMin - 100', 'dataMax + 100']} />
            <Tooltip
              contentStyle={{
                backgroundColor: theme === 'dark' ? 'rgba(24, 24, 27, 0.9)' : theme === 'gradient' ? 'rgba(255, 255, 255, 0.2)' : 'rgba(255, 255, 255, 0.9)',
                backdropFilter: 'blur(10px)',
                border: theme === 'dark' ? '1px solid rgba(244, 63, 94, 0.3)' : theme === 'gradient' ? '1px solid rgba(255,255,255,0.2)' : '1px solid #e5e7eb',
                borderRadius: '12px',
                boxShadow: '0 4px 12px rgba(0,0,0,0.1)',
                color: theme === 'dark' ? '#fff' : theme === 'gradient' ? '#fff' : '#374151'
              }}
              itemStyle={{ color: theme === 'dark' ? '#fff' : theme === 'gradient' ? '#fff' : '#374151' }}
              labelStyle={{ color: theme === 'dark' ? '#fff' : theme === 'gradient' ? '#fff' : '#111827', fontWeight: 'bold' }}
            />
            <Area
              type="monotone"
              dataKey="price"
              stroke={strokeColor}
              strokeWidth={2.5}
              fill={gradientColor}
              dot={false}
            />
          </AreaChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
};

export default TradingChart;
